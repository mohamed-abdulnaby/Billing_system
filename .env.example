# FMRZ Billing System - Environment Configuration Template
# Copy this file to '.env' and fill in your real credentials

# Database Configuration
DB_URL=jdbc:postgresql://your-neondb-url.neon.tech/neondb?sslmode=require
DB_USER=neondb_owner
DB_PASSWORD=your_secure_password_here

# System Paths (For CDR Ingestion)
CDR_INPUT_PATH=./input
CDR_PROCESSED_PATH=./processed

# Java Performance Tuning
JAVA_OPTS="-XX:+UseParallelGC -Xms256m -Xmx512m"
